# ==============================================================
# Social Scheduler — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or .env to version control.
# ==============================================================

# --------------------------------------------------------------
# Supabase — Authentication & Storage
# Get these from: https://supabase.com/dashboard → Project Settings → API
# --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --------------------------------------------------------------
# Database — PostgreSQL via Prisma
# Supabase provides both a pooled (PgBouncer) URL and a direct URL.
# For Neon, use the pooler URL for DATABASE_URL and direct URL for DIRECT_URL.
# Find these in: Supabase Dashboard → Settings → Database
# --------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# --------------------------------------------------------------
# App URL
# Used to build absolute URLs for OAuth redirect URIs.
# For local development: http://localhost:3000
# For production: https://your-domain.com
# --------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------------------------
# LinkedIn OAuth — for posting on behalf of users
# Create an app at: https://www.linkedin.com/developers/apps
# Required scopes: openid, profile, email, w_member_social
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/linkedin/callback
# --------------------------------------------------------------
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# --------------------------------------------------------------
# LinkedIn State Signing Secret
# A random secret used to sign the OAuth state parameter (CSRF protection).
# Generate with: openssl rand -base64 32
# --------------------------------------------------------------
LINKEDIN_STATE_SECRET=your-random-state-secret

# --------------------------------------------------------------
# Cron Secret
# Protects the /api/cron/publish endpoint from unauthorized calls.
# Set the same value as the CRON_SECRET env var in Vercel.
# Vercel automatically passes this as a Bearer token when invoking crons.
# Generate with: openssl rand -base64 32
# --------------------------------------------------------------
CRON_SECRET=your-cron-secret
